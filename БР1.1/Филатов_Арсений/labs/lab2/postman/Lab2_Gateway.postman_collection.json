{
  "info": {
    "name": "Lab2 — полное API через gateway",
    "_postman_id": "lab2-gateway-full-collection",
    "description": "Все публичные маршруты **через gateway** (`baseUrl`, обычно http://127.0.0.1:3000).\n\n**Перед сценарием:** заполните `candidateAccessToken` и `employerAccessToken`** вручную** из ответов Login/Register.\n\nПорядок «с нуля»: зарегистрировать employer и candidate → залогинить обоих (скопировать accessToken) → employer: создать компанию (заполнить companyId из ответа) → создать вакансию со status `published`, при необходимости PUT навыков → candidate: PUT профиль → POST резюме (resumeId из ответа) → навыки/education/work по желанию → POST отклик.\n\n`skillIdsJson` по умолчанию `[1,2]` — id из каталога GET /skills (после seed).\n\nОчереди: **RabbitMQ** (не Kafka). После POST отклика смотрите логи сервиса employer.\n\nВнутренние `/internal/...` **не включены**: gateway их не проксирует.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3000"
    },
    {
      "key": "candidateEmail",
      "value": "postman.candidate@example.com"
    },
    {
      "key": "candidatePassword",
      "value": "password123"
    },
    {
      "key": "employerEmail",
      "value": "postman.employer@example.com"
    },
    {
      "key": "employerPassword",
      "value": "password123"
    },
    {
      "key": "candidateAccessToken",
      "value": ""
    },
    {
      "key": "employerAccessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "companyId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "vacancyId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "resumeId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "educationId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "workExperienceId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "applicationId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "skillIdsJson",
      "value": "[1,2]"
    }
  ],
  "item": [
    {
      "name": "Служебное",
      "item": [
        {
          "name": "Gateway health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Каталог (без авторизации)",
      "item": [
        {
          "name": "Отрасли",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/industries"
          }
        },
        {
          "name": "Уровни опыта",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/experience-levels"
          }
        },
        {
          "name": "Навыки",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/skills?page=1&pageSize=50"
          }
        }
      ]
    },
    {
      "name": "Авторизация",
      "item": [
        {
          "name": "Регистрация candidate",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{candidateEmail}}\",\n  \"password\": \"{{candidatePassword}}\",\n  \"roleCode\": \"candidate\"\n}"
            }
          }
        },
        {
          "name": "Регистрация employer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{employerEmail}}\",\n  \"password\": \"{{employerPassword}}\",\n  \"roleCode\": \"employer\"\n}"
            }
          }
        },
        {
          "name": "Вход candidate",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{candidateEmail}}\",\n  \"password\": \"{{candidatePassword}}\"\n}"
            },
            "description": "Скопируйте из ответа поле **accessToken** в переменную коллекции `candidateAccessToken`."
          }
        },
        {
          "name": "Вход employer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{employerEmail}}\",\n  \"password\": \"{{employerPassword}}\"\n}"
            },
            "description": "Скопируйте из ответа **accessToken** в `employerAccessToken`."
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Подставьте refresh из последнего login/register."
          }
        }
      ]
    },
    {
      "name": "Пользователь (/me)",
      "item": [
        {
          "name": "GET /me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/me",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{candidateAccessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "PATCH /me",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/me",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{candidateAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": true\n}"
            }
          }
        }
      ]
    },
    {
