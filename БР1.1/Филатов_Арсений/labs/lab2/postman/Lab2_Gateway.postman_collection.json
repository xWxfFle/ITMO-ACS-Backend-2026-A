    {
      "name": "Работодатель — компании и вакансии",
      "item": [
        {
          "name": "Мои членства",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/me/employer/memberships",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employerAccessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Создать компанию",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/companies",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employerAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
