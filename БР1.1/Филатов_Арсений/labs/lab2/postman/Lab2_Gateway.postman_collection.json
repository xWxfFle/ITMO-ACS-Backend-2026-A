              "raw": "{\n  \"name\": \"Компания Postman Labs\",\n  \"industryId\": 1,\n  \"description\": \"Тест работодателя\"\n}"
            },
            "description": "Подставьте валидный industryId из GET /industries. Ответ содержит id компании → в `companyId`."
          }
        },
        {
          "name": "Компания по id GET",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/companies/{{companyId}}"
          }
        },
