    {
      "name": "Отклики (application-сервис)",
      "item": [
        {
          "name": "Создать отклик",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/vacancies/{{vacancyId}}/applications",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{candidateAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resumeId\": {{resumeId}}\n}"
            },
            "description": "**Важно:** в JSON должно быть число resumeId. В редакторе переменная без кавычек может не подставиться как число — при необходимости впишите id вручную числом.\nОтправляет событие в **RabbitMQ**."
          }
        },
        {
          "name": "Мои отклики (кандидат)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/me/applications?page=1&pageSize=20",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{candidateAccessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Отклики на вакансию (работодатель)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/vacancies/{{vacancyId}}/applications?page=1&pageSize=20",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employerAccessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Изменить статус отклика",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/applications/{{applicationId}}",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employerAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"viewed\"\n}"
            },
            "description": "`applicationId` — из списка откликов или ответа POST отклика."
          }
        }
      ]
    }
  ]
}